class MemoryTier(Enum):
    M0 = "M0_PERMANENTE"
    M1 = "M1_ALTO_USO"
    M2 = "M2_MEDIO_USO"
    M3 = "M3_BAIXO_USO"


class TipoInteracao(Enum):
    HUMANO_AI = "humano_ai"
    AI_AI = "ai_ai"
    AI_PESQUISA = "ai_pesquisa"
    AI_PLANO = "ai_plano"
    AI_ACAO_EXECUTADA = "ai_acao_executada"
    AI_REFLEXAO = "ai_reflexao"


